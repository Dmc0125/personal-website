---
import Icon from "./Icon.astro";
import { type Link } from "../content/links";

interface Props {
    copyright: string;
    links: Link[];
}
const { copyright, links } = Astro.props;
---

<footer class="w-full px-4 pb-10 pt-6 mt-16 border-t border-gray-800">
    <div
        class="w-full max-w-[800px] mx-auto flex gap-4 flex-col sm:flex-row justify-between items-center"
    >
        <div class="flex gap-4 items-center">
            {
                links.map((link) => (
                    <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-400 hover:text-teal-600 transition-all"
                        aria-label={link.ariaLabel}
                    >
                        <Icon name={link.icon} className="size-6" />
                    </a>
                ))
            }
        </div>

        <span class="text-gray-400 text-sm">
            © {new Date().getFullYear()}
            {copyright}
        </span>
    </div>
</footer>
