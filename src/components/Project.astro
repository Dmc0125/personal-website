---
import ProjectDemo from "./ProjectDemo.astro";

interface Props {
    name: string;
    description: string;
    url?: string;
    githubUrl?: string;

    imageUrl?: string;
    videoUrl?: string;
    technologies: string[];
}

const { name, description, url, githubUrl, technologies, imageUrl, videoUrl } =
    Astro.props;
---

<div class="w-full flex flex-col sm:grid grid-cols-2 gap-4">
    <div>
        <div class="w-full gap-4">
            <h4 class="text-gray-200 text-lg font-semibold">{name}</h4>
            <div
                class="mt-1 flex items-center gap-2 text-gray-400 transition-all"
            >
                {
                    url && (
                        <>
                            <a
                                href={url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="hover:text-teal-600"
                                aria-label={`${name} website`}
                            >
                                Website
                            </a>
                            <span>&bull;</span>
                        </>
                    )
                }
                {
                    githubUrl && (
                        <a
                            class="hover:text-teal-600"
                            href={githubUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={`${name} GitHub`}
                        >
                            Github
                        </a>
                    )
                }
            </div>
        </div>
        <p class="text-gray-400 mt-2">
            {description}
        </p>
        <ul class="w-full mt-2 flex flex-wrap items-center gap-4 text-sm">
            {
                technologies.map((t) => (
                    <li class="px-2 py-1 bg-zinc-800 text-gray-400 rounded">
                        {t}
                    </li>
                ))
            }
        </ul>
    </div>
    <ProjectDemo name={name} videoUrl={videoUrl} imageUrl={imageUrl} />
</div>
