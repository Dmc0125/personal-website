---

{
    contributions.length > 0 ? (
        <section
            id="contributions"
            class="w-full px-4 mt-16 sm:mt-32 max-w-[800px] mx-auto"
        >
            <div class="flex gap-4 items-center">
                <div class="h-[2px] w-full bg-gray-700" />
                <h3 class="text-gray-400 text-lg font-semibold shrink-0 uppercase">
                    Contributions
                </h3>
                <span class="text-lg font-medium text-gray-700">03</span>
            </div>

            <ul class="mt-10 flex flex-col gap-8">
                {contributions.map((contribution) => (
                    <li class="flex flex-col gap-2">
                        <div class="flex gap-4">
                            <span
                                class={
                                    contribution.state === "Merged"
                                        ? "text-teal-600"
                                        : "text-gray-400"
                                }
                            >
                                <Icon
                                    name={contribution.icon}
                                    className="size-5"
                                />
                            </span>
                            <p class="text-gray-200">{contribution.title}</p>
                        </div>

                        <div class="flex items-center gap-4 text-gray-400 text-sm">
                            <a
                                href={contribution.prUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="hover:text-gray-200 transition-all"
                            >
                                {contribution.repoName} #{contribution.number}
                            </a>

                            <div
                                class={
                                    "w-fit py-0.5 px-2 rounded " +
                                    (contribution.state === "Open"
                                        ? "bg-zinc-800 text-gray-400"
                                        : "bg-teal-600/30 text-teal-600")
                                }
                            >
                                {contribution.state}
                            </div>
                        </div>

                        <div class="flex gap-x-4 gap-y-2 flex-wrap">
                            <span class="text-sm text-gray-400 flex gap-2">
                                <Icon name="calendar" className="size-4" />
                                Created at {contribution.createdAt}
                            </span>
                            {contribution.mergedAt && (
                                <span class="text-sm text-teal-600 flex gap-2">
                                    <Icon name="clock" className="size-4" />
                                    Merged at {contribution.mergedAt}
                                </span>
                            )}
                        </div>
                    </li>
                ))}
            </ul>
        </section>
    ) : (
        <section
            id="contributions"
            class="w-full px-4 mt-16 sm:mt-32 max-w-[800px] mx-auto"
        >
            <div class="flex gap-4 items-center">
                <div class="h-[2px] w-full bg-gray-700" />
                <h3 class="text-gray-400 text-lg font-semibold shrink-0 uppercase">
                    Contributions
                </h3>
                <span class="text-lg font-medium text-gray-700">02</span>
            </div>

            <p class="mt-10 text-gray-400">
                Unable to display contributions at this time.
            </p>
        </section>
    )
}
