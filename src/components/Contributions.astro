---
import { GITHUB_ACCESS_TOKEN } from "astro:env/server";

import Icon from "./Icon.astro";

const GITHUB_API_URL = "https://api.github.com";
const issuesResponse = await fetch(
    `${GITHUB_API_URL}/search/issues?q=is:pr+author:dmc0125`,
    {
        headers: {
            Accept: "application/vnd.github+json",
            "X-GitHub-Api-Version": "2026-03-10",
            Authorization: `Bearer ${GITHUB_ACCESS_TOKEN}`,
            "user-agent": "dmc0125",
        },
    },
);

type IssueState = "open" | "closed";

type IssueItem = {
    id: number;
    html_url: string;
    repository_url: string;
    title: string;
    created_at: string;
    updated_at: string;
    state: IssueState;
    number: number;
    body: string;
    pull_request?: {
        url: string;
        html_url: string;
        diff_url: string;
        patch_url: string;
        merged_at: string | null;
    };
};

type IssuesData = {
    total_count: number;
    incomplete_results: boolean;
    items: IssueItem[];
};

type ContributionState = "Open" | "Closed" | "Merged";

type Contribution = {
    title: string;
    // description?: string;
    // body: string;
    prUrl: string;
    repoUrl: string;
    repoName: string;
    number: number;
    state: ContributionState;
    createdAt: string;
    mergedAt?: string;
    icon: string;
};

const contributions: Contribution[] = [];

if (issuesResponse.ok) {
    const issuesResponseData = (await issuesResponse.json()) as IssuesData;

    for (const issue of issuesResponseData.items) {
        const [_, repoName] = issue.repository_url.split("repos/");

        let state: ContributionState = "Open";
        let icon = "branch-out";
        if (issue.state === "closed") {
            if (issue.pull_request?.merged_at !== null) {
                state = "Merged";
                icon = "branch-in";
            } else {
                state = "Closed";
                icon = "branch-out";
            }
        }

        const createdAt = new Date(issue.created_at).toLocaleDateString(
            undefined,
            {
                year: "numeric",
                month: "short",
                day: "numeric",
            },
        );
        const mergedAt = issue.pull_request?.merged_at
            ? new Date(issue.pull_request.merged_at).toLocaleDateString(
                  undefined,
                  {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                  },
              )
            : undefined;

        const contribution = {
            title: issue.title,
            prUrl: issue.html_url,
            repoUrl: issue.repository_url,
            number: issue.number,
            // body: issue.body,
            createdAt,
            mergedAt,
            repoName,
            state,
            icon,
        } as Contribution;
        contributions.push(contribution);
    }

    // const redis = new Redis({
