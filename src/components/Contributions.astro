    //     const key = contributionDataKey(contribution.number.toString());
    //     const savedContribution = savedContributionsKeys.find(
    //         (savedContribution) => savedContribution === key,
    //     );
    //
    //     if (!savedContribution) {
    //         contributionsToSave.push({
    //             issueNumber: contribution.number,
    //             title: contribution.title,
    //             body: contribution.body,
    //         });
    //     }
    // }
    //
    // {
    //     const tx = redis.multi();
    //     for (const contribution of contributionsToSave) {
    //         const { issueNumber, ...data } = contribution;
    //         tx.hset(contributionDataKey(issueNumber.toString()), data);
